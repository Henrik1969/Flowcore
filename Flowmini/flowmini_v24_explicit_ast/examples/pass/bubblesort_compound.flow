program bubblesort_compound

main {
    arr  : list<int>([1,9,3,5,8,2,2,6,4])
    len  : int(length(arr))
    zero : int(0)
    one  : int(1)
    i    : int(0)
    j    : int(0)
    tmp  : int(0)

    while i < len {
        zero -> j

        while j + one < len {
            if arr[j] > arr[j + one] {
                arr[j] -> tmp
                arr[j + one] -> arr[j]
                tmp -> arr[j + one]
            }

            j + one -> j
        }

        i + one -> i
    }

    print arr
}
