module fibonacci_general

producer stdin : stdin.text
node parse : parse.int.to_record
node zero : const.int
node one : const.int
node init_a : const.int
node init_b : const.int
node init_i : const.int
node check : int.lt
node route : route.bool
node add_ab : int.add
node copy_b_to_a : record.copy
node copy_tmp_to_b : record.copy
node inc_i : int.add
node print : stdout.int_line
sink halt : halt.record

policy parse.out = "n"
policy zero.out = "zero"
policy zero.value = 0
policy one.out = "one"
policy one.value = 1
policy init_a.out = "a"
policy init_a.value = 0
policy init_b.out = "b"
policy init_b.value = 1
policy init_i.out = "i"
policy init_i.value = 0
policy check.lhs = "i"
policy check.rhs = "n"
policy check.out = "keep_going"
policy route.path = "keep_going"
policy add_ab.lhs = "a"
policy add_ab.rhs = "b"
policy add_ab.out = "tmp"
policy copy_b_to_a.from = "b"
policy copy_b_to_a.to = "a"
policy copy_tmp_to_b.from = "tmp"
policy copy_tmp_to_b.to = "b"
policy inc_i.lhs = "i"
policy inc_i.rhs = "one"
policy inc_i.out = "i"
policy print.path = "a"

wire stdin.out => parse.in
wire parse.out => zero.in
wire zero.out => one.in
wire one.out => init_a.in
wire init_a.out => init_b.in
wire init_b.out => init_i.in
wire init_i.out => check.in
wire check.out => route.in
wire route.true => add_ab.in
wire add_ab.out => copy_b_to_a.in
wire copy_b_to_a.out => copy_tmp_to_b.in
wire copy_tmp_to_b.out => inc_i.in
wire inc_i.out => check.in
wire route.false => print.in
wire print.out => halt.in
