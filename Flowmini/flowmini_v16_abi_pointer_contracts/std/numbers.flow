module std_numbers

type Integer refines int {
}

type NonNegativeInteger refines Integer {
    invariant value >= 0
}

type PositiveInteger refines NonNegativeInteger {
    invariant value > 0
}

type NonPositiveInteger refines Integer {
    invariant value <= 0
}

type NegativeInteger refines NonPositiveInteger {
    invariant value < 0
}

type ZeroInteger refines Integer {
    invariant value == 0
}

type Percent refines NonNegativeInteger {
    invariant value <= 100
}

type PortNumber refines PositiveInteger {
    invariant value <= 65535
}
