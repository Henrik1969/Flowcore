import "../std/math.flow"
import "../std/collatz.flow"

module capable_imported

main {
    zero  : int(0)
    one   : int(1)
    two   : int(2)
    three : int(3)
    four  : int(4)
    five  : int(5)
    nine  : int(9)
    ten   : int(10)
    forty_two : int(42)

    result : int(0)

    identity(forty_two) -> result
    print result

    square(add(three, four)) -> result
    print result

    factorial(five) -> result
    print result

    collatz_next(five) -> result
    print result

    choose_larger(nine, four) -> result
    print result

    matrix : array<int>[2, 3]([1,2,3,4,5,6])
    row    : int(1)
    col    : int(2)
    value  : int(0)

    matrix[row, col] -> value
    print value

    value + ten -> matrix[row, col]
    print matrix
}
