unit min_list

producer stdin : stdin.text
node parse : parse.int.to_record
node arr : list.from_ints
node len : list.length
node zero : const.int
node one : const.int
node get_min : list.get
node set_i : const.int
node check : int.lt
node route_loop : route.bool
node get_current : list.get
node cmp : int.lt
node route_cmp : route.bool
node copy_min : record.copy
node inc_i : int.add
node print : stdout.int_line
sink halt : halt.record

policy parse.out = "dummy"
policy arr.out = "arr"
policy arr.values = "1,9,3,5,8,2,2,6,4"
policy len.list = "arr"
policy len.out = "len"
policy zero.out = "zero"
policy zero.value = 0
policy one.out = "one"
policy one.value = 1
policy get_min.list = "arr"
policy get_min.index = "zero"
policy get_min.out = "min"
policy set_i.out = "i"
policy set_i.value = 1
policy check.lhs = "i"
policy check.rhs = "len"
policy check.out = "cond"
policy route_loop.path = "cond"
policy get_current.list = "arr"
policy get_current.index = "i"
policy get_current.out = "current"
policy cmp.lhs = "current"
policy cmp.rhs = "min"
policy cmp.out = "take"
policy route_cmp.path = "take"
policy copy_min.from = "current"
policy copy_min.to = "min"
policy inc_i.lhs = "i"
policy inc_i.rhs = "one"
policy inc_i.out = "i"
policy print.path = "min"

wire stdin.out => parse.in
wire parse.out => arr.in
wire arr.out => len.in
wire len.out => zero.in
wire zero.out => one.in
wire one.out => get_min.in
wire get_min.out => set_i.in
wire set_i.out => check.in
wire check.out => route_loop.in
wire route_loop.true => get_current.in
wire get_current.out => cmp.in
wire cmp.out => route_cmp.in
wire route_cmp.true => copy_min.in
wire copy_min.out => inc_i.in
wire route_cmp.false => inc_i.in
wire inc_i.out => check.in
wire route_loop.false => print.in
wire print.out => halt.in
