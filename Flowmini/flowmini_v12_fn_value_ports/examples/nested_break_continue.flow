module nested_break_continue

main {
    outer : int(0)
    inner : int(0)
    zero  : int(0)
    one   : int(1)
    three : int(3)

    while outer < three {
        zero -> inner

        while inner < three {
            if inner == one {
                break
            }

            print outer
            inner + one -> inner
        }

        outer + one -> outer
    }
}
