module power2_general

producer stdin : stdin.text
node parse : parse.int.to_record
node zero : const.int
node one : const.int
node base : const.int
node acc : const.int
node check : int.gt
node route : route.bool
node mul : int.mul
node dec : int.sub
node print : stdout.int_line
sink halt : halt.record

policy parse.out = "exp"
policy zero.out = "zero"
policy zero.value = 0
policy one.out = "one"
policy one.value = 1
policy base.out = "base"
policy base.value = 2
policy acc.out = "acc"
policy acc.value = 1
policy check.lhs = "exp"
policy check.rhs = "zero"
policy check.out = "keep_going"
policy route.path = "keep_going"
policy mul.lhs = "acc"
policy mul.rhs = "base"
policy mul.out = "acc"
policy dec.lhs = "exp"
policy dec.rhs = "one"
policy dec.out = "exp"
policy print.path = "acc"

wire stdin.out => parse.in
wire parse.out => zero.in
wire zero.out => one.in
wire one.out => base.in
wire base.out => acc.in
wire acc.out => check.in
wire check.out => route.in
wire route.true => mul.in
wire mul.out => dec.in
wire dec.out => check.in
wire route.false => print.in
wire print.out => halt.in
