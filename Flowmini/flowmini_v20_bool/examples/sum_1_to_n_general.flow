module sum_1_to_n_general

producer stdin : stdin.text
node parse : parse.int.to_record
node zero : const.int
node one : const.int
node acc : const.int
node check : int.gt
node route : route.bool
node add : int.add
node dec : int.sub
node print : stdout.int_line
sink halt : halt.record

policy parse.out = "n"
policy zero.out = "zero"
policy zero.value = 0
policy one.out = "one"
policy one.value = 1
policy acc.out = "acc"
policy acc.value = 0
policy check.lhs = "n"
policy check.rhs = "zero"
policy check.out = "keep_going"
policy route.path = "keep_going"
policy add.lhs = "acc"
policy add.rhs = "n"
policy add.out = "acc"
policy dec.lhs = "n"
policy dec.rhs = "one"
policy dec.out = "n"
policy print.path = "acc"

wire stdin.out => parse.in
wire parse.out => zero.in
wire zero.out => one.in
wire one.out => acc.in
wire acc.out => check.in
wire check.out => route.in
wire route.true => add.in
wire add.out => dec.in
wire dec.out => check.in
wire route.false => print.in
wire print.out => halt.in
