module internal_nested_record_demo

type Point {
    field x : int
    field y : int
}

type Gear {
    field teeth : int
    field rpm : int
}

type GearPair {
    field driver : Gear
    field driven : Gear
}

fn ratio_hint(pair : GearPair): int {
    result : int(0)
    pair.driver.teeth * pair.driven.rpm -> result
    result -> return
}

main {
    driver : Gear({teeth:12, rpm:100})
    driven : Gear({teeth:36, rpm:0})
    pair : GearPair({driver:driver, driven:driven})
    value : int(0)
    result : int(0)

    pair.driver.teeth -> value
    print value

    42 -> pair.driven.rpm
    pair.driven.rpm -> value
    print value

    ratio_hint(pair) -> result
    print result
}
