module bubblesort_list

producer stdin : stdin.text
node parse : parse.int.to_record
node arr : list.from_ints
node len : list.length
node zero_outer : const.int
node one : const.int
node outer_check : int.lt
node outer_route : route.bool
node zero_i : const.int
node limit1 : int.sub
node limit2 : int.sub
node inner_check : int.lt
node inner_route : route.bool
node compare_swap : list.compare_swap_asc
node inc_i : int.add
node inc_outer : int.add
node print : list.print_int_lines
sink halt : halt.record

policy parse.out = "dummy"
policy arr.out = "arr"
policy arr.values = "1,9,3,5,8,2,2,6,4"
policy len.list = "arr"
policy len.out = "len"
policy zero_outer.out = "outer"
policy zero_outer.value = 0
policy one.out = "one"
policy one.value = 1
policy outer_check.lhs = "outer"
policy outer_check.rhs = "len"
policy outer_check.out = "outer_cond"
policy outer_route.path = "outer_cond"
policy zero_i.out = "i"
policy zero_i.value = 0
policy limit1.lhs = "len"
policy limit1.rhs = "outer"
policy limit1.out = "limit"
policy limit2.lhs = "limit"
policy limit2.rhs = "one"
policy limit2.out = "limit"
policy inner_check.lhs = "i"
policy inner_check.rhs = "limit"
policy inner_check.out = "inner_cond"
policy inner_route.path = "inner_cond"
policy compare_swap.list = "arr"
policy compare_swap.a = "i"
policy compare_swap.b_offset = 1
policy inc_i.lhs = "i"
policy inc_i.rhs = "one"
policy inc_i.out = "i"
policy inc_outer.lhs = "outer"
policy inc_outer.rhs = "one"
policy inc_outer.out = "outer"
policy print.list = "arr"

wire stdin.out => parse.in
wire parse.out => arr.in
wire arr.out => len.in
wire len.out => zero_outer.in
wire zero_outer.out => one.in
wire one.out => outer_check.in
wire outer_check.out => outer_route.in
wire outer_route.true => zero_i.in
wire zero_i.out => limit1.in
wire limit1.out => limit2.in
wire limit2.out => inner_check.in
wire inner_check.out => inner_route.in
wire inner_route.true => compare_swap.in
wire compare_swap.out => inc_i.in
wire inc_i.out => inner_check.in
wire inner_route.false => inc_outer.in
wire inc_outer.out => outer_check.in
wire outer_route.false => print.in
wire print.out => halt.in
