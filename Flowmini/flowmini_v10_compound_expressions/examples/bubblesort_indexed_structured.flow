module bubblesort_indexed_structured

main {
    arr   : list<int>([1,9,3,5,8,2,2,6,4])
    len   : int(length(arr))
    zero  : int(0)
    one   : int(1)
    i     : int(0)
    j     : int(0)
    next  : int(0)
    a     : int(0)
    b     : int(0)

    while i < len {
        zero -> j

        while j < len {
            j + one -> next

            if next < len {
                arr[j] -> a
                arr[next] -> b

                if a > b {
                    b -> arr[j]
                    a -> arr[next]
                }
            }

            j + one -> j
        }

        i + one -> i
    }

    print arr
}
