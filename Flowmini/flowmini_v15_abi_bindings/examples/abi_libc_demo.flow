import "../std/abi/libc.flow"

module abi_libc_demo

main {
    len      : c_size_t(0)
    status   : c_int(0)
    negative : c_int(-42)
    big_neg  : c_long(-123456)
    out      : c_int(0)
    long_out : c_long(0)
    message  : c_string("Hello from Flowmini ABI")

    strlen("Hello") -> len
    print len

    abs(negative) -> out
    print out

    labs(big_neg) -> long_out
    print long_out

    puts(message) -> status
    print status
}
