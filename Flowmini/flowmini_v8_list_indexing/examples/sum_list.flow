module sum_list

producer stdin : stdin.text
node parse : parse.int.to_record
node arr : list.from_ints
node len : list.length
node zero_i : const.int
node zero_sum : const.int
node one : const.int
node check : int.lt
node route : route.bool
node get : list.get
node add_sum : int.add
node inc_i : int.add
node print : stdout.int_line
sink halt : halt.record

policy parse.out = "dummy"
policy arr.out = "arr"
policy arr.values = "1,9,3,5,8,2,2,6,4"
policy len.list = "arr"
policy len.out = "len"
policy zero_i.out = "i"
policy zero_i.value = 0
policy zero_sum.out = "sum"
policy zero_sum.value = 0
policy one.out = "one"
policy one.value = 1
policy check.lhs = "i"
policy check.rhs = "len"
policy check.out = "cond"
policy route.path = "cond"
policy get.list = "arr"
policy get.index = "i"
policy get.out = "current"
policy add_sum.lhs = "sum"
policy add_sum.rhs = "current"
policy add_sum.out = "sum"
policy inc_i.lhs = "i"
policy inc_i.rhs = "one"
policy inc_i.out = "i"
policy print.path = "sum"

wire stdin.out => parse.in
wire parse.out => arr.in
wire arr.out => len.in
wire len.out => zero_i.in
wire zero_i.out => zero_sum.in
wire zero_sum.out => one.in
wire one.out => check.in
wire check.out => route.in
wire route.true => get.in
wire get.out => add_sum.in
wire add_sum.out => inc_i.in
wire inc_i.out => check.in
wire route.false => print.in
wire print.out => halt.in
