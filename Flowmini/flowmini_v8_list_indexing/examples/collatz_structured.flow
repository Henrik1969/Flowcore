module collatz_structured

main {
    n     : int(stdin.int())
    zero  : int(0)
    one   : int(1)
    two   : int(2)
    three : int(3)
    rem   : int(0)
    tmp   : int(0)

    while n > one {
        print n
        n % two -> rem

        if rem == zero {
            n / two -> n
        } else {
            n * three -> tmp
            tmp + one -> n
        }
    }

    print n
}
